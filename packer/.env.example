# Hetzner Cloud API token
HCLOUD_TOKEN=
PKR_VAR_hcloud_token=

# Packer build options
PKR_VAR_server_type=cpx22
PKR_VAR_location=hel1

# Deploy options
SERVER_NAME=
SERVER_TYPE=cpx22
SERVER_LOCATION=hel1
# SSH keys to inject — required for SSH access (use one or the other)
SSH_KEY_NAMES=
SSH_KEY_LABELS=
# Assign an existing primary IPv4 (use label selector or explicit IP)
PRIMARY_IPV4_LABEL=
PRIMARY_IPV4=
VOLUME_IDS=
VOLUME_MOUNT=/mnt/data

# Auth — at least one required
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# OpenClaw
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_CONFIG_DIR=/mnt/data/.openclaw
OPENCLAW_WORKSPACE_DIR=/mnt/data/workspace
OPENCLAW_SANDBOX=
OPENCLAW_DOCKER_SOCKET=/var/run/docker.sock
OPENCLAW_HOME_VOLUME=
OPENCLAW_EXTRA_MOUNTS=
OPENCLAW_DOCKER_APT_PACKAGES=
OPENCLAW_EXTENSIONS=
OPENCLAW_INSTALL_DOCKER_CLI=
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=
