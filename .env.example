# Hetzner Cloud API token (used by Packer as PKR_VAR_hcloud_token)
PKR_VAR_hcloud_token=

# Packer build options (optional — overrides variables.pkr.hcl defaults)
# PKR_VAR_server_type=cx42
# PKR_VAR_location=hel1
# PKR_VAR_snapshot_name=ubuntu-24-pa-dev

# OpenClaw
OPENCLAW_IMAGE=openclaw:local
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_CONFIG_DIR=/root/.openclaw
OPENCLAW_WORKSPACE_DIR=/root/.openclaw/workspace
OPENCLAW_SANDBOX=
OPENCLAW_DOCKER_SOCKET=/var/run/docker.sock
OPENCLAW_HOME_VOLUME=
OPENCLAW_EXTRA_MOUNTS=
OPENCLAW_DOCKER_APT_PACKAGES=
OPENCLAW_EXTENSIONS=
OPENCLAW_INSTALL_DOCKER_CLI=
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=
